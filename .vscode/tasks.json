{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-api",
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "${workspaceFolder}/API/API.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Format Code",
      "type": "shell",
      "command": "dotnet format",
      "group": "none",
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    }
  ]
}
